<Window x:Class="TechnologistModule.Dialogs.EditExtruderProgramDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="✏️ Редактирование программы экструдера" Height="447" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,-16">
        <StackPanel Margin="25,25,25,-15">
            <TextBlock Text="Редактирование программы экструдера" FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Название" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtName" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="Описание" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtDescription" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="ID рецептуры" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtRecipeId" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="ID оборудования" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtEquipmentId" Height="35" FontSize="14" Margin="0,0,0,20" Padding="8,5"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnSave" Content="💾 Сохранить" Background="#27AE60" Foreground="White" 
                        Width="120" Height="38" FontSize="14" Margin="0,0,15,0"/>
                <Button x:Name="btnCancel" Content="❌ Отмена" Background="#95A5A6" Foreground="White" 
                        Width="120" Height="38" FontSize="14"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>