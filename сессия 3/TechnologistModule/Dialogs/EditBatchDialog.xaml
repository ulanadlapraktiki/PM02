<Window x:Class="TechnologistModule.Dialogs.EditBatchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="✏️ Редактирование партии" Height="365" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,-16">
        <StackPanel Margin="25,25,25,-21">
            <TextBlock Text="Редактирование партии" FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Номер партии" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtBatchNumber" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5" IsReadOnly="True" Background="#F0F0F0"/>

            <TextBlock Text="ID заказа" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtOrderId" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5" IsReadOnly="True" Background="#F0F0F0"/>

            <TextBlock Text="Фактическое количество (кг)" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtActualQuantity" Height="35" FontSize="14" Margin="0,0,0,20" Padding="8,5"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnSave" Content="💾 Сохранить" Background="#27AE60" Foreground="White" 
                        Width="120" Height="38" FontSize="14" Margin="0,0,15,0"/>
                <Button x:Name="btnCancel" Content="❌ Отмена" Background="#95A5A6" Foreground="White" 
                        Width="120" Height="38" FontSize="14"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>