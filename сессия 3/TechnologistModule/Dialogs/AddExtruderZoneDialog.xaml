<Window x:Class="TechnologistModule.Dialogs.AddExtruderZoneDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление зоны экструдера" Height="531" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1">
        <StackPanel Margin="25,25,25,-21">
            <TextBlock Text="Новая зона экструдера" FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Номер зоны" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtZoneNumber" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5" Text="1"/>

            <TextBlock Text="Целевая температура" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtTargetTemperature" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5" Text="180"/>

            <TextBlock Text="Допуск" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtTolerance" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5" Text="5"/>

            <TextBlock Text="Целевое давление" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtTargetPressure" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5" Text="50"/>

            <TextBlock Text="Целевая скорость" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtTargetSpeed" Height="35" FontSize="14" Margin="0,0,0,20" Padding="8,5" Text="150"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="btnSave" Content="Сохранить" Background="#27AE60" Foreground="White" 
                        Width="120" Height="38" FontSize="14" Margin="0,0,15,0"/>
                <Button x:Name="btnCancel" Content="Отмена" Background="#95A5A6" Foreground="White" 
                        Width="120" Height="38" FontSize="14"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>