<Window x:Class="TechnologistModule.Dialogs.AddProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="➕ Добавление продукта" Height="472" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1">
        <StackPanel Margin="25,25,25,13">
            <TextBlock Text="Новый продукт" FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#2C3E50"/>

            <TextBlock Text="Код продукта" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
            <TextBox x:Name="txtCode" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="Наименование" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
            <TextBox x:Name="txtName" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="Тип продукта" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
            <ComboBox x:Name="cmbType" Height="35" FontSize="14" Margin="0,0,0,15" Padding="5">
                <ComboBoxItem Content="гербицид"/>
                <ComboBoxItem Content="инсектицид"/>
                <ComboBoxItem Content="фунгицид"/>
                <ComboBoxItem Content="регулятор роста"/>
            </ComboBox>

            <TextBlock Text="Форма выпуска" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
            <ComboBox x:Name="cmbForm" Height="35" FontSize="14" Margin="0,0,0,25" Padding="5">
                <ComboBoxItem Content="жидкий"/>
                <ComboBoxItem Content="порошок"/>
                <ComboBoxItem Content="гранулы"/>
                <ComboBoxItem Content="эмульсия"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="btnSave" Content="💾 Сохранить" Background="#27AE60" Foreground="White" 
                        Width="130" Height="40" FontSize="14" Margin="0,0,15,0" Cursor="Hand"/>
                <Button x:Name="btnCancel" Content="❌ Отмена" Background="#95A5A6" Foreground="White" 
                        Width="130" Height="40" FontSize="14" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>