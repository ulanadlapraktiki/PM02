<UserControl x:Class="TechnologistModule.Views.BatchesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🏷️ Производственные партии" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnAdd" Content="➕ Создать партию" Background="#27AE60" Foreground="White" Padding="15,8" Height="40"/>
            <Button x:Name="btnEdit" Content="✏️ Редактировать" Margin="10,0,0,0" Background="#3498DB" Foreground="White" Padding="15,8" Height="40" IsEnabled="False"/>
            <Button x:Name="btnDelete" Content="🗑️ Удалить" Margin="10,0,0,0" Background="#E74C3C" Foreground="White" Padding="15,8" Height="40" IsEnabled="False"/>
            <Button x:Name="btnStart" Content="▶ Запустить" Margin="10,0,0,0" Background="#3498DB" Foreground="White" Padding="15,8" Height="40" IsEnabled="False"/>
            <Button x:Name="btnComplete" Content="✅ Завершить" Margin="10,0,0,0" Background="#27AE60" Foreground="White" Padding="15,8" Height="40" IsEnabled="False"/>
            <Button x:Name="btnRefresh" Content="🔄 Обновить" Margin="10,0,0,0" Background="#7F8C8D" Foreground="White" Padding="15,8" Height="40"/>
            <ProgressBar x:Name="progress" Width="100" Height="4" Margin="10,0,0,0" IsIndeterminate="True" Visibility="Collapsed"/>
        </StackPanel>

        <DataGrid x:Name="grid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                  Margin="0,10,0,0" FontSize="13" AlternatingRowBackground="#F8F9FA"
                  SelectionChanged="Grid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер партии" Binding="{Binding BatchNumber}" Width="150"/>
                <DataGridTextColumn Header="ID заказа" Binding="{Binding OrderId}" Width="80"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Время начала" Binding="{Binding StartTime, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                <DataGridTextColumn Header="Время окончания" Binding="{Binding EndTime, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                <DataGridTextColumn Header="Факт, кг" Binding="{Binding ActualQuantityKg}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>