<UserControl x:Class="TechnologistModule.Views.ExtruderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="⚙️ Программы экструдера" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnAdd" Content="➕ Создать программу" Background="#27AE60" Foreground="White" Padding="15,8" Height="40"/>
            <Button x:Name="btnEdit" Content="✏️ Редактировать" Margin="10,0,0,0" Background="#3498DB" Foreground="White" Padding="15,8" IsEnabled="False" Height="40"/>
            <Button x:Name="btnDelete" Content="🗑️ Удалить" Margin="10,0,0,0" Background="#E74C3C" Foreground="White" Padding="15,8" IsEnabled="False" Height="40"/>
            <Button x:Name="btnActivate" Content="▶ Активировать" Margin="10,0,0,0" Background="#F39C12" Foreground="White" Padding="15,8" IsEnabled="False" Height="40"/>
            <Button x:Name="btnRefresh" Content="🔄 Обновить" Margin="10,0,0,0" Background="#7F8C8D" Foreground="White" Padding="15,8" Height="40"/>
            <ProgressBar x:Name="progress" Width="100" Height="4" Margin="10,0,0,0" IsIndeterminate="True" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Таблица программ -->
        <DataGrid x:Name="grid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                  Margin="0,10,0,10" FontSize="13" AlternatingRowBackground="#F8F9FA"
                  SelectionChanged="Grid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="250"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Зоны экструдера -->
        <Border Grid.Row="3" Background="#F8F9FA" CornerRadius="8" Padding="10" Margin="0,5,0,0">
            <StackPanel>
                <TextBlock Text="📊 Зоны экструдера" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="btnAddZone" Content="➕ Добавить зону" Background="#27AE60" Foreground="White" 
                            Width="120" Height="30" FontSize="12" Visibility="Collapsed"/>
                    <Button x:Name="btnDeleteZone" Content="🗑️ Удалить зону" Background="#E74C3C" Foreground="White" 
                            Width="120" Height="30" FontSize="12" Margin="10,0,0,0" Visibility="Collapsed"/>
                </StackPanel>
                <DataGrid x:Name="zonesGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                          Height="150" FontSize="12" AlternatingRowBackground="#FFFFFF"
                          SelectionChanged="ZonesGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Зона" Binding="{Binding ZoneNumber}" Width="60"/>
                        <DataGridTextColumn Header="Температура" Binding="{Binding TargetTemperature}" Width="100"/>
                        <DataGridTextColumn Header="Допуск" Binding="{Binding Tolerance}" Width="80"/>
                        <DataGridTextColumn Header="Давление" Binding="{Binding TargetPressure}" Width="80"/>
                        <DataGridTextColumn Header="Скорость" Binding="{Binding TargetSpeed}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>