<Window x:Class="LaboratoryModule.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АгроКонтроль - Лаборатория" Height="557" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="0,0,0,-6">
        <Border Background="White" CornerRadius="10" Margin="20,20,20,0" Height="517" VerticalAlignment="Top">
            <StackPanel Margin="25">
                <TextBlock Text="АгроКонтроль" FontSize="24" FontWeight="Bold" 
                           Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Модуль лаборатории" FontSize="14" Foreground="Gray" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Логин" FontWeight="SemiBold" Margin="0,5"/>
                <TextBox x:Name="txtLogin" Height="35" Margin="0,0,0,15"/>

                <TextBlock Text="Пароль" FontWeight="SemiBold" Margin="0,5"/>
                <PasswordBox x:Name="txtPassword" Height="35" Margin="0,0,0,15"/>

                <TextBlock Text="Код с картинки" FontWeight="SemiBold" Margin="0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Image x:Name="imgCaptcha" Width="180" Height="55" Stretch="Fill"/>
                    <Button x:Name="btnRefresh" Content="⟳" Width="45" Height="55" Margin="10,0,0,0" FontSize="18"/>
                </StackPanel>
                <TextBox x:Name="txtCaptcha" Height="35" Margin="0,0,0,15"/>

                <TextBlock x:Name="lblError" Foreground="Red" Margin="0,5" TextWrapping="Wrap"/>

                <Button x:Name="btnLogin" Content="ВОЙТИ" Background="#3498DB" Foreground="White" 
                        FontWeight="Bold" Height="45" FontSize="14" Margin="0,10,0,5" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>