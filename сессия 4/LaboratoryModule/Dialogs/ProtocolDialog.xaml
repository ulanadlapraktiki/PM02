<Window x:Class="LaboratoryModule.Dialogs.ProtocolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📄 Протокол испытаний" Height="744" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Background="#2C3E50" Padding="15" Grid.Row="0">
            <TextBlock Text="ПРОТОКОЛ ИСПЫТАНИЙ" FontSize="20" FontWeight="Bold" Foreground="White" 
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Содержимое протокола -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>
                <TextBlock x:Name="lblTitle" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Border BorderBrush="Black" BorderThickness="1" Padding="10" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Номер протокола:" FontWeight="Bold" Grid.Row="0" Grid.Column="0"/>
                        <TextBlock x:Name="lblProtocolNumber" Grid.Row="0" Grid.Column="1"/>
                        <TextBlock Text="Дата:" FontWeight="Bold" Grid.Row="0" Grid.Column="2"/>
                        <TextBlock x:Name="lblDate" Grid.Row="0" Grid.Column="3"/>

                        <TextBlock Text="Номер партии:" FontWeight="Bold" Grid.Row="1" Grid.Column="0"/>
                        <TextBlock x:Name="lblBatchNumber" Grid.Row="1" Grid.Column="1"/>
                        <TextBlock Text="Продукт/Материал:" FontWeight="Bold" Grid.Row="1" Grid.Column="2"/>
                        <TextBlock x:Name="lblMaterial" Grid.Row="1" Grid.Column="3"/>

                        <TextBlock Text="Тип контроля:" FontWeight="Bold" Grid.Row="2" Grid.Column="0"/>
                        <TextBlock x:Name="lblControlType" Grid.Row="2" Grid.Column="1"/>
                        <TextBlock Text="Лаборант:" FontWeight="Bold" Grid.Row="2" Grid.Column="2"/>
                        <TextBlock x:Name="lblAnalyst" Grid.Row="2" Grid.Column="3"/>

                        <TextBlock Text="Решение:" FontWeight="Bold" Grid.Row="3" Grid.Column="0"/>
                        <TextBlock x:Name="lblDecision" Grid.Row="3" Grid.Column="1" FontWeight="Bold"/>
                        <TextBlock Text="Комментарий:" FontWeight="Bold" Grid.Row="3" Grid.Column="2"/>
                        <TextBlock x:Name="lblComment" Grid.Row="3" Grid.Column="3"/>
                    </Grid>
                </Border>

                <TextBlock Text="РЕЗУЛЬТАТЫ ИСПЫТАНИЙ" FontSize="16" FontWeight="Bold" Margin="0,10,0,10"/>

                <DataGrid x:Name="gridResults" AutoGenerateColumns="False" Height="162" Margin="0,0,0,15">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Параметр" Binding="{Binding ParameterName}" Width="150"/>
                        <DataGridTextColumn Header="Норма (мин)" Binding="{Binding MinValue}" Width="100"/>
                        <DataGridTextColumn Header="Норма (макс)" Binding="{Binding MaxValue}" Width="100"/>
                        <DataGridTextColumn Header="Ед.изм" Binding="{Binding Unit}" Width="80"/>
                        <DataGridTextColumn Header="Значение" Binding="{Binding MeasuredValue}" Width="100"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding IsValid}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding IsValid}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsValid}" Value="True">
                                            <Setter Property="Text" Value="✅ OK"/>
                                            <Setter Property="Foreground" Value="Green"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsValid}" Value="False">
                                            <Setter Property="Text" Value="❌ Отклонение"/>
                                            <Setter Property="Foreground" Value="Red"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Комментарий" Binding="{Binding AnalystComment}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border BorderBrush="#BDC3C7" BorderThickness="1" Padding="10" Margin="0,10">
                    <StackPanel>
                        <TextBlock Text="Подписи:" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="Лаборант: ___________________" Margin="0,5"/>
                        <TextBlock Text="Начальник лаборатории: ___________________" Margin="0,5"/>
                        <TextBlock Text="Дата: ___________________" Margin="0,5"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button x:Name="btnPrint" Content="🖨️ Печать" Background="#3498DB" Foreground="White" 
                    Width="120" Height="40" Margin="0,0,15,0" Cursor="Hand"/>
            <Button x:Name="btnSavePdf" Content="📄 Сохранить PDF" Background="#27AE60" Foreground="White" 
                    Width="150" Height="40" Margin="0,0,15,0" Cursor="Hand"/>
            <Button x:Name="btnClose" Content="❌ Закрыть" Background="#95A5A6" Foreground="White" 
                    Width="100" Height="40" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>