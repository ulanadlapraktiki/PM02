<Window x:Class="LaboratoryModule.Dialogs.DecisionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Принятие решения" Height="449" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,-16">
        <StackPanel Margin="25">
            <TextBlock Text="Принятие решения по результатам анализа" FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Статус проверки" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <Border x:Name="statusBorder" Background="#27AE60" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                <TextBlock x:Name="lblStatus" Text="Все параметры в норме" Foreground="White" 
                           HorizontalAlignment="Center" FontWeight="SemiBold"/>
            </Border>

            <TextBlock Text="Решение" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <RadioButton x:Name="rbApprove" Content="✅ РАЗРЕШИТЬ (партия допускается)" 
                         GroupName="Decision" IsChecked="True" Margin="0,5" FontSize="13"/>
            <RadioButton x:Name="rbBlock" Content="❌ ЗАБЛОКИРОВАТЬ (партия брак)" 
                         GroupName="Decision" Margin="0,5" FontSize="13"/>

            <TextBlock Text="Комментарий (обязателен при блокировке)" FontWeight="SemiBold" Margin="0,10,0,5"/>
            <TextBox x:Name="txtComment" Height="60" FontSize="14" TextWrapping="Wrap" 
                     AcceptsReturn="True" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock x:Name="lblError" Foreground="Red" FontSize="12" 
                       TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnConfirm" Content="✅ Подтвердить решение" Background="#3498DB" 
                        Foreground="White" Width="175" Height="38" FontSize="13" Margin="0,0,15,0" Cursor="Hand"/>
                <Button x:Name="btnCancel" Content="❌ Отмена" Background="#95A5A6" Foreground="White" 
                        Width="120" Height="38" FontSize="14" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>