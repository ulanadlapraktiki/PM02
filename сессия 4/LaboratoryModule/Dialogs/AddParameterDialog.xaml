<Window x:Class="LaboratoryModule.Dialogs.AddParameterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление параметра" Height="481" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,-16">
        <StackPanel Margin="25">
            <TextBlock Text="Новый параметр контроля" FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Наименование параметра" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtParameterName" Height="35" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="Минимальное значение" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtMinValue" Height="35" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="Максимальное значение" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtMaxValue" Height="35" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="Единица измерения" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtUnit" Height="35" Margin="0,0,0,20" Padding="8,5" Text="%"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnSave" Content="💾 Сохранить" Background="#27AE60" Foreground="White" 
                        Width="120" Height="38" Margin="0,0,15,0" Cursor="Hand"/>
                <Button x:Name="btnCancel" Content="❌ Отмена" Background="#95A5A6" Foreground="White" 
                        Width="120" Height="38" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>