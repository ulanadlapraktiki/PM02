<UserControl x:Class="OperatorModule.Views.BatchProgramView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Background="#2C3E50" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="lblBatchNumber" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="lblProduct" FontSize="12" Foreground="#BDC3C7"/>
                    <TextBlock x:Name="lblStatus" FontSize="12" Foreground="#F39C12" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock x:Name="lblCurrentStep" FontSize="14" Foreground="#3498DB" FontWeight="Bold"/>
                    <TextBlock x:Name="lblTime" FontSize="11" Foreground="#BDC3C7"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Список шагов -->
        <ListBox x:Name="listSteps" Grid.Row="1" Height="380" SelectionChanged="ListSteps_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" Margin="0,2" Background="White" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="{Binding StepName}" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="{Binding Status}" FontSize="10" Foreground="Gray"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnBack" Content="◀ НАЗАД" Background="#95A5A6" Foreground="White" Width="150" Height="40" Margin="0,0,15,0" Cursor="Hand"/>
            <Button x:Name="btnCompleteBatch" Content="✅ ЗАВЕРШИТЬ ПАРТИЮ" Background="#27AE60" Foreground="White" Width="200" Height="40" Cursor="Hand" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</UserControl>