<Window x:Class="OperatorModule.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АгроКонтроль - Аппаратчик" Height="573" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid>
        <Border Background="White" CornerRadius="10" Margin="20,20,20,10">
            <StackPanel Margin="25">
                <!-- Логотип -->
                <TextBlock Text="АгроКонтроль" FontSize="24" FontWeight="Bold" 
                           Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Модуль аппаратчика" FontSize="14" Foreground="Gray" 
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <!-- Поле логина -->
                <TextBlock Text="Логин" FontWeight="SemiBold" Margin="0,5"/>
                <TextBox x:Name="txtLogin" Height="35" Margin="0,0,0,15" FontSize="14" 
                         Background="#F8F9FA" BorderBrush="#BDC3C7" BorderThickness="1"/>

                <!-- Поле пароля -->
                <TextBlock Text="Пароль" FontWeight="SemiBold" Margin="0,5"/>
                <PasswordBox x:Name="txtPassword" Height="35" Margin="0,0,0,15" FontSize="14" 
                             Background="#F8F9FA" BorderBrush="#BDC3C7" BorderThickness="1"/>

                <!-- Капча -->
                <TextBlock Text="Код с картинки" FontWeight="SemiBold" Margin="0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Image x:Name="imgCaptcha" Width="180" Height="55" Stretch="Fill" 
                           VerticalAlignment="Center"/>
                    <Button x:Name="btnRefresh" Content="⟳" Width="45" Height="55" 
                            Margin="10,0,0,0" FontSize="18" Cursor="Hand"
                            Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="1"/>
                </StackPanel>
                <TextBox x:Name="txtCaptcha" Height="35" Margin="0,0,0,15" FontSize="14"
                         Background="#F8F9FA" BorderBrush="#BDC3C7" BorderThickness="1"/>

                <!-- Ошибка -->
                <TextBlock x:Name="lblError" Foreground="#E74C3C" Margin="0,5" 
                           TextWrapping="Wrap" FontSize="12" Visibility="Collapsed"/>

                <!-- Кнопка входа -->
                <Button x:Name="btnLogin" Content="ВОЙТИ" Background="#3498DB" 
                        Foreground="White" FontWeight="Bold" Height="45" FontSize="14" 
                        Margin="0,10,0,5" Cursor="Hand" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>