<Window x:Class="OperatorModule.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:OperatorModule.Views"
        Title="АгроКонтроль - Аппаратчик" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <!-- Аватар и информация о пользователе -->
                <Border Background="#1A252F" Height="130" Margin="0,0,0,10">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button x:Name="btnAvatar" Width="65" Height="65" Cursor="Hand" 
                                BorderThickness="0" Background="Transparent" 
                                ToolTip="Нажмите для смены аватарки">
                            <Border Width="65" Height="65" CornerRadius="32.5" ClipToBounds="True" Background="#3498DB">
                                <Image x:Name="imgAvatar" Width="65" Height="65" Stretch="UniformToFill"/>
                            </Border>
                        </Button>
                        <TextBlock x:Name="lblUserName" Text="Загрузка..." Foreground="White" 
                                   FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        <TextBlock x:Name="lblUserRole" Text="" Foreground="#BDC3C7" 
                                   FontSize="10" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="lblShift" Text="Смена: Дневная" Foreground="#F39C12" 
                                   FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button x:Name="btnActiveBatches" Content="🏭 Активные партии" Margin="10,5" 
                        Background="#34495E" Foreground="White" Height="45" 
                        FontSize="14" FontWeight="Bold" Cursor="Hand"/>
                <Button x:Name="btnEquipment" Content="📊 Экструдер LIVE" Margin="10,5" 
                        Background="Transparent" Foreground="White" Height="40" Cursor="Hand"/>
                <Button x:Name="btnLog" Content="📋 Журнал партии" Margin="10,5" 
                        Background="Transparent" Foreground="White" Height="40" Cursor="Hand"/>
                <Button x:Name="btnReport" Content="⚠️ Сообщить о проблеме" Margin="10,5" 
                        Background="Transparent" Foreground="White" Height="40" Cursor="Hand"/>

                <Separator Margin="10,15" Background="#555"/>

                <Button x:Name="btnLogout" Content="🚪 Выход" Margin="10,10" 
                        Background="#C0392B" Foreground="White" Height="35" Cursor="Hand"/>
                <!-- Логотип внизу -->
                <Image Source="7f81ed43b3fd67f2533f71d17c6275d0.ico" Width="84" Height="145" Margin="10,20,10,10" HorizontalAlignment="Center" Opacity="0.8"/>
            </StackPanel>
        </Border>

        <ContentControl x:Name="contentControl" Grid.Column="1" Margin="15"/>
    </Grid>
</Window>