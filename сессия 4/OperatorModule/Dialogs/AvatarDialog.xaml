<Window x:Class="OperatorModule.Dialogs.AvatarDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор аватарки" Height="469" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1">
        <StackPanel Margin="25">
            <TextBlock Text="Загрузите аватар" FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="#2C3E50"/>

            <Border BorderBrush="#BDC3C7" BorderThickness="2" CornerRadius="8" 
                    Width="140" Height="140" HorizontalAlignment="Center" Margin="0,0,0,15" Background="#F8F9FA">
                <Image x:Name="imgAvatar" Width="140" Height="140" Stretch="UniformToFill"/>
            </Border>

            <Button x:Name="btnSelect" Content="📁 Выбрать файл" Background="#3498DB" 
                    Foreground="White" Height="40" FontSize="14" Margin="0,5" Cursor="Hand"/>
            <Button x:Name="btnSave" Content="💾 Сохранить" Background="#27AE60" 
                    Foreground="White" Height="40" FontSize="14" Margin="0,5" Cursor="Hand"/>
            <Button x:Name="btnCancel" Content="❌ Отмена" Background="#95A5A6" 
                    Foreground="White" Height="40" FontSize="14" Margin="0,5" Cursor="Hand"/>

            <TextBlock x:Name="lblInfo" Foreground="#E74C3C" FontSize="11" 
                       TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            <TextBlock Text="Поддерживаемые форматы: JPG, PNG, BMP. Максимум 2 MB" 
                       Foreground="#7F8C8D" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>
    </Border>
</Window>