<Window x:Class="OperatorModule.Dialogs.StepExecutionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выполнение шага" Height="650" Width="600"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Topmost="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="White" CornerRadius="10" BorderBrush="#2C3E50" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок для перетаскивания -->
            <Border Grid.Row="0" Background="#2C3E50" CornerRadius="10,10,0,0" 
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="⚙️ Выполнение шага" FontSize="14" FontWeight="Bold" 
                               Foreground="White" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    <Button x:Name="btnClose" Content="✕" Width="30" Height="30" 
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="Transparent" Foreground="White" BorderThickness="0"
                            FontSize="16" Cursor="Hand" Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- Содержимое с прокруткой -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <!-- Заголовок шага -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Text="⚙️" FontSize="28" Margin="0,0,10,0"/>
                        <TextBlock x:Name="lblStepName" FontSize="20" FontWeight="Bold" 
                                   Foreground="#2C3E50" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Инструкция -->
                    <Border Background="#FFF8E1" CornerRadius="8" Padding="12" Margin="0,0,0,15" 
                            BorderBrush="#F39C12" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📋 ИНСТРУКЦИЯ" FontWeight="Bold" Foreground="#F39C12" Margin="0,0,0,5"/>
                            <TextBlock x:Name="lblInstruction" TextWrapping="Wrap" FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <!-- Параметры -->
                    <TextBlock Text="⚙️ ПАРАМЕТРЫ" FontWeight="Bold" FontSize="14" Foreground="#2C3E50" Margin="0,0,0,10"/>

                    <StackPanel x:Name="panelParams" Margin="0,0,0,15">
                        <!-- Динамическое добавление параметров -->
                    </StackPanel>

                    <!-- Комментарий -->
                    <TextBlock Text="💬 КОММЕНТАРИЙ ОПЕРАТОРА" FontWeight="Bold" FontSize="14" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtComment" Height="80" TextWrapping="Wrap" 
                             AcceptsReturn="True" Margin="0,0,0,20" 
                             Padding="8,5" BorderBrush="#BDC3C7" BorderThickness="1"/>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button x:Name="btnComplete" Content="✅ ЗАВЕРШИТЬ ШАГ" Background="#27AE60" 
                                Foreground="White" Width="190" Height="45" FontSize="14" 
                                Margin="0,0,15,0" Cursor="Hand" FontWeight="Bold">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                            </Button.Effect>
                        </Button>
                        <Button x:Name="btnCancel" Content="❌ ОТМЕНА" Background="#95A5A6" 
                                Foreground="White" Width="130" Height="45" FontSize="14" Cursor="Hand"/>
                    </StackPanel>

                    <TextBlock x:Name="lblError" Foreground="#E74C3C" FontSize="12" 
                               TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>