<Application x:Class="TechnologistModule.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TechnologistModule">
    <Application.Resources>
        <ResourceDictionary>
            <local:ResolvedConverter x:Key="ResolvedConverter"/>

            <!-- Тень для окон -->
            <DropShadowEffect x:Key="DropShadow" BlurRadius="10" ShadowDepth="3" Opacity="0.3"/>

            <Style TargetType="Button">
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="8,0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>
            <Style TargetType="PasswordBox">
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="8,0"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>
            <Style TargetType="DatePicker">
                <Setter Property="Height" Value="32"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="Height" Value="32"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="5,0"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>