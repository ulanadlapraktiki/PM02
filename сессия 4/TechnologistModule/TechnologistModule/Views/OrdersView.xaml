<UserControl x:Class="TechnologistModule.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Производственные заказы" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="btnAdd" Content="➕ Создать заказ" Background="#27AE60" Foreground="White" Padding="15,8" Height="40"/>
            <Button x:Name="btnStart" Content="▶ Запустить" Margin="15,0,0,0" Background="#3498DB" Foreground="White" Padding="15,8" Height="40"/>
            <Button x:Name="btnRefresh" Content="🔄 Обновить" Margin="15,0,0,0" Background="#7F8C8D" Foreground="White" Padding="15,8" Height="40"/>
            <ProgressBar x:Name="progress" Width="100" Height="4" Margin="15,0,0,0" IsIndeterminate="True" Visibility="Collapsed"/>
        </StackPanel>

        <DataGrid x:Name="grid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                  Margin="0,10,0,0" FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер заказа" Binding="{Binding OrderNumber}" Width="150"/>
                <DataGridTextColumn Header="Плановое количество, кг" Binding="{Binding PlannedQuantityKg}" Width="150"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Плановая дата" Binding="{Binding PlannedStartDate, StringFormat=dd.MM.yyyy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>