<Window x:Class="TechnologistModule.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АгроКонтроль - Вход" Height="500" Width="400" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Border>
        <StackPanel Margin="20" Background="White" VerticalAlignment="Center">
            <TextBlock Text="АгроКонтроль" FontSize="22" FontWeight="Bold" 
                        HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Логин" Margin="0,5"/>
            <TextBox x:Name="txtLogin" Height="35"/>

            <TextBlock Text="Пароль" Margin="0,10,0,5"/>
            <PasswordBox x:Name="txtPassword" Height="35"/>

            <TextBlock Text="Код с картинки" Margin="0,10,0,5"/>
            <StackPanel Orientation="Horizontal">
                <Image x:Name="imgCaptcha" Width="160" Height="50" Stretch="Fill"/>
                <Button x:Name="btnRefresh" Content="⟳" Width="40" Margin="5,0,0,0"/>
            </StackPanel>
            <TextBox x:Name="txtCaptcha" Height="35" Margin="0,5,0,0"/>

            <TextBlock x:Name="lblError" Foreground="Red" Margin="0,10,0,0" TextWrapping="Wrap"/>

            <Button x:Name="btnLogin" Content="Войти" Background="SteelBlue" Foreground="White" 
                    FontWeight="Bold" Height="40" Margin="0,15,0,0"/>
        </StackPanel>
    </Border>
</Window>