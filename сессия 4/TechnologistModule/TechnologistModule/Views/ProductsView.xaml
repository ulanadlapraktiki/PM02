<UserControl x:Class="TechnologistModule.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Продукция" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="btnAdd" Content="➕ Добавить" Background="#27AE60" Foreground="White" Padding="15,8" Height="40"/>
            <Button x:Name="btnRefresh" Content="🔄 Обновить" Margin="15,0,0,0" Background="#7F8C8D" Foreground="White" Padding="15,8" Height="40"/>
            <ProgressBar x:Name="progress" Width="100" Height="4" Margin="15,0,0,0" IsIndeterminate="True" Visibility="Collapsed"/>
        </StackPanel>

        <DataGrid x:Name="grid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                  Margin="0,10,0,0" FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="120"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="250"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding ProductType}" Width="120"/>
                <DataGridTextColumn Header="Форма" Binding="{Binding Form}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>