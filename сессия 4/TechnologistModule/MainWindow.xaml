<Window x:Class="TechnologistModule.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TechnologistModule.Views"
        Title="АгроКонтроль - Технолог" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <!-- Аватарка пользователя -->
                <Border Background="#1A252F" Height="120" Margin="0,0,0,10">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button x:Name="btnAvatar" Width="70" Height="70" Cursor="Hand" 
                BorderThickness="0" Background="Transparent" 
                Padding="0" Margin="0"
                ToolTip="Нажмите для смены аватарки">
                            <Border Width="70" Height="70" CornerRadius="35" ClipToBounds="True" Background="#3498DB">
                                <Image x:Name="imgAvatar" Width="70" Height="70" Stretch="UniformToFill" 
                       StretchDirection="Both"/>
                            </Border>
                        </Button>
                        <TextBlock x:Name="lblUserName" Text="Загрузка..." Foreground="White" 
                   FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        <TextBlock x:Name="lblUserRole" Text="" Foreground="#BDC3C7" 
                   FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button x:Name="btnDashboard" Content="🏠 Главная" Margin="10,2" 
                        Background="#34495E" Foreground="White" Height="40" Cursor="Hand"/>
                <Button x:Name="btnProducts" Content="📦 Продукция" Margin="10,2" 
                        Background="Transparent" Foreground="White" Height="40" Cursor="Hand"/>
                <Button x:Name="btnRecipes" Content="📝 Рецептуры" Margin="10,2" 
                        Background="Transparent" Foreground="White" Height="40" Cursor="Hand"/>
                <Button x:Name="btnTechMaps" Content="🗺️ Тех. карты" Margin="10,2" 
                        Background="Transparent" Foreground="White" Height="40" Cursor="Hand"/>
                <Button x:Name="btnOrders" Content="📋 Заказы" Margin="10,2" 
                        Background="Transparent" Foreground="White" Height="40" Cursor="Hand"/>
                <Button x:Name="btnBatches" Content="🏷️ Партии" Margin="10,2" 
                        Background="Transparent" Foreground="White" Height="40" Cursor="Hand"/>
                <Button x:Name="btnExtruder" Content="⚙️ Экструдер" Margin="10,2" 
                        Background="Transparent" Foreground="White" Height="40" Cursor="Hand"/>
                <Button x:Name="btnDeviations" Content="⚠️ События" Margin="10,2" 
                        Background="Transparent" Foreground="White" Height="40" Cursor="Hand"/>
                <Button x:Name="btnReports" Content="📊 Отчеты" Margin="10,2" 
                        Background="Transparent" Foreground="White" Height="40" Cursor="Hand"/>

                <Separator Margin="10,15" Background="#555"/>

                <Button x:Name="btnLogout" Content="🚪 Выход" Margin="10,0" 
                        Background="#C0392B" Foreground="White" Height="35" Cursor="Hand"/>
                <!-- Логотип внизу -->
                <Image Source="7f81ed43b3fd67f2533f71d17c6275d0.ico" Width="50" Height="50" Margin="10,20,10,10" HorizontalAlignment="Center" Opacity="0.8"/>
            </StackPanel>
        </Border>

        <!-- Контент -->
        <ContentControl x:Name="contentControl" Grid.Column="1" Margin="15"/>
    </Grid>
</Window>