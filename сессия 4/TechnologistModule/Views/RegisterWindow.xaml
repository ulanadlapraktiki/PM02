<Window x:Class="TechnologistModule.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="650" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Background="#2C3E50">
        <Border Background="White" CornerRadius="10" Margin="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="25">
                    <TextBlock Text="Регистрация пользователя" FontSize="20" FontWeight="Bold" 
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBlock Text="Логин *" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtUsername" Height="35" Margin="0,0,0,15"/>

                    <TextBlock Text="Пароль *" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="txtPassword" Height="35" Margin="0,0,0,15"/>

                    <TextBlock Text="Подтверждение пароля *" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="txtConfirmPassword" Height="35" Margin="0,0,0,15"/>

                    <TextBlock Text="ФИО *" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtFullName" Height="35" Margin="0,0,0,15"/>

                    <TextBlock Text="Роль" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cmbRole" Height="35" Margin="0,0,0,15">
                        <ComboBoxItem>technologist - Технолог</ComboBoxItem>
                        <ComboBoxItem>operator - Аппаратчик</ComboBoxItem>
                        <ComboBoxItem>laboratory - Лаборант</ComboBoxItem>
                        <ComboBoxItem>manager - Руководитель</ComboBoxItem>
                    </ComboBox>

                    <TextBlock Text="Email" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtEmail" Height="35" Margin="0,0,0,15"/>

                    <TextBlock Text="Телефон" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtPhone" Height="35" Margin="0,0,0,15"/>

                    <TextBlock Text="Отдел" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtDepartment" Height="35" Margin="0,0,0,15"/>

                    <TextBlock Text="Код с картинки *" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                        <Image x:Name="imgCaptcha" Width="160" Height="50" Stretch="Fill"/>
                        <Button x:Name="btnRefreshCaptcha" Content="⟳" Width="40" Height="50" Margin="10,0,0,0"/>
                    </StackPanel>
                    <TextBox x:Name="txtCaptcha" Height="35" Margin="0,0,0,15"/>

                    <TextBlock x:Name="lblError" Foreground="Red" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <Button x:Name="btnRegister" Content="Зарегистрироваться" Background="#27AE60" 
                                Foreground="White" Width="170" Height="40" Margin="0,0,10,0"/>
                        <Button x:Name="btnCancel" Content="Отмена" Background="#95A5A6" 
                                Foreground="White" Width="120" Height="40"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>