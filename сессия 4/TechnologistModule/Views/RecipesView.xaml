<UserControl x:Class="TechnologistModule.Views.RecipesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📝 Рецептуры" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnAdd" Content="➕ Создать" Background="#27AE60" Foreground="White" Padding="15,8" Height="40"/>
            <Button x:Name="btnApprove" Content="✅ Утвердить" Margin="10,0,0,0" Background="#F39C12" Foreground="White" Padding="15,8" Height="40"/>
            <Button x:Name="btnEdit" Content="✏️ Редактировать" Margin="10,0,0,0" Background="#3498DB" Foreground="White" Padding="15,8" Height="40" IsEnabled="False"/>
            <Button x:Name="btnDelete" Content="🗑️ Удалить" Margin="10,0,0,0" Background="#E74C3C" Foreground="White" Padding="15,8" Height="40" IsEnabled="False"/>
            <Button x:Name="btnRefresh" Content="🔄 Обновить" Margin="10,0,0,0" Background="#7F8C8D" Foreground="White" Padding="15,8" Height="40"/>
            <ProgressBar x:Name="progress" Width="100" Height="4" Margin="10,0,0,0" IsIndeterminate="True" Visibility="Collapsed"/>
        </StackPanel>

        <DataGrid x:Name="grid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                  Margin="0,10,0,0" FontSize="13" AlternatingRowBackground="#F8F9FA"
                  SelectionChanged="Grid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Версия" Binding="{Binding Version}" Width="80"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Продукт ID" Binding="{Binding ProductId}" Width="80"/>
                <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Форма редактирования -->
        <Border x:Name="panelEdit" Background="White" BorderBrush="Gray" BorderThickness="1" 
                CornerRadius="10" Width="350" Height="300" Visibility="Collapsed"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Margin="20">
                <TextBlock Text="✏️ Редактирование рецептуры" FontSize="18" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Text="Название" FontWeight="SemiBold"/>
                <TextBox x:Name="txtName" Height="35" Margin="0,0,0,10"/>

                <TextBlock Text="Версия" FontWeight="SemiBold"/>
                <TextBox x:Name="txtVersion" Height="35" Margin="0,0,0,10"/>

                <TextBlock Text="ID продукта" FontWeight="SemiBold"/>
                <TextBox x:Name="txtProductId" Height="35" Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="btnSaveEdit" Content="💾 Сохранить" Background="#27AE60" Foreground="White" Width="100" Height="35" Margin="0,0,10,0"/>
                    <Button x:Name="btnCancelEdit" Content="❌ Отмена" Background="#95A5A6" Foreground="White" Width="100" Height="35"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>