<UserControl x:Class="TechnologistModule.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📊 Отчеты" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Панель фильтров -->
        <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Параметры отчета" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <!-- Тип отчета -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Тип отчета:" Width="100" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbReportType" Width="250" Height="35" SelectedIndex="0">
                        <ComboBoxItem>📋 Отчет по партиям</ComboBoxItem>
                        <ComboBoxItem>⚠️ Отчет по отклонениям</ComboBoxItem>
                        <ComboBoxItem>📝 Отчет по рецептурам</ComboBoxItem>
                        <ComboBoxItem>📦 Отчет по продукции</ComboBoxItem>
                        <ComboBoxItem>⚙️ Отчет по экструдеру</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <!-- Период -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Период:" Width="100" VerticalAlignment="Center"/>
                    <DatePicker x:Name="dpStart" Width="130" Height="35"/>
                    <TextBlock Text=" - " VerticalAlignment="Center" Margin="5,0"/>
                    <DatePicker x:Name="dpEnd" Width="130" Height="35"/>
                </StackPanel>

                <!-- Быстрые фильтры -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Быстрый период:" Width="100" VerticalAlignment="Center"/>
                    <Button x:Name="btnToday" Content="Сегодня" Width="80" Height="30" Margin="0,0,5,0" Background="#E0E0E0" Cursor="Hand"/>
                    <Button x:Name="btnWeek" Content="Неделя" Width="80" Height="30" Margin="0,0,5,0" Background="#E0E0E0" Cursor="Hand"/>
                    <Button x:Name="btnMonth" Content="Месяц" Width="80" Height="30" Margin="0,0,5,0" Background="#E0E0E0" Cursor="Hand"/>
                    <Button x:Name="btnQuarter" Content="Квартал" Width="80" Height="30" Background="#E0E0E0" Cursor="Hand"/>
                </StackPanel>

                <!-- Кнопки действий -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="btnGenerate" Content="📄 Сформировать отчет" Background="#3498DB" 
                            Foreground="White" Width="180" Height="35" Cursor="Hand"/>
                    <Button x:Name="btnExportExcel" Content="📎 Экспорт в Excel" Background="#27AE60" 
                            Foreground="White" Width="150" Height="35" Margin="10,0,0,0" Cursor="Hand"/>
                    <Button x:Name="btnPrint" Content="🖨️ Печать" Background="#7F8C8D" 
                            Foreground="White" Width="100" Height="35" Margin="10,0,0,0" Cursor="Hand"/>
                    <ProgressBar x:Name="progress" Width="100" Height="4" Margin="10,0,0,0" IsIndeterminate="True" Visibility="Collapsed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Итоговая информация -->
        <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <WrapPanel>
                <TextBlock x:Name="lblDateRange" Text="Период: " FontWeight="SemiBold" Margin="0,0,20,0"/>
                <TextBlock x:Name="lblTotalInfo" Text="Всего записей: 0" FontWeight="SemiBold" Margin="0,0,20,0"/>
                <TextBlock x:Name="lblTotalSum" Text="Общее количество: 0 кг" FontWeight="SemiBold"/>
            </WrapPanel>
        </Border>

        <!-- Таблица отчета -->
        <DataGrid x:Name="grid" Grid.Row="3" AutoGenerateColumns="True" IsReadOnly="True" 
                  Margin="0,10,0,0" FontSize="13" AlternatingRowBackground="#F8F9FA"/>
    </Grid>
</UserControl>