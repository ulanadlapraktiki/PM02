<Window x:Class="TechnologistModule.Dialogs.AddProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="➕ Добавление продукта" Height="500" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1">
        <StackPanel Margin="25">
            <TextBlock Text="Новый продукт" FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#2C3E50"/>

            <TextBlock Text="Код продукта" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtCode" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="Наименование" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtName" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="Тип продукта" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbType" Height="35" FontSize="14" Margin="0,0,0,15" Padding="5">
                <ComboBoxItem>гербицид</ComboBoxItem>
                <ComboBoxItem>инсектицид</ComboBoxItem>
                <ComboBoxItem>фунгицид</ComboBoxItem>
                <ComboBoxItem>регулятор роста</ComboBoxItem>
                <ComboBoxItem>акарицид</ComboBoxItem>
                <ComboBoxItem>родентицид</ComboBoxItem>
                <ComboBoxItem>нематоцид</ComboBoxItem>
                <ComboBoxItem>моллюскоцид</ComboBoxItem>
                <ComboBoxItem>бактерицид</ComboBoxItem>
                <ComboBoxItem>вирусоцид</ComboBoxItem>
                <ComboBoxItem>удобрение</ComboBoxItem>
                <ComboBoxItem>стимулятор</ComboBoxItem>
                <ComboBoxItem>антидот</ComboBoxItem>
                <ComboBoxItem>адъювант</ComboBoxItem>
                <ComboBoxItem>десикант</ComboBoxItem>
            </ComboBox>

            <TextBlock Text="Форма выпуска" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbForm" Height="35" FontSize="14" Margin="0,0,0,25" Padding="5">
                <ComboBoxItem>жидкий</ComboBoxItem>
                <ComboBoxItem>порошок</ComboBoxItem>
                <ComboBoxItem>гранулы</ComboBoxItem>
                <ComboBoxItem>эмульсия</ComboBoxItem>
                <ComboBoxItem>суспензия</ComboBoxItem>
                <ComboBoxItem>концентрат</ComboBoxItem>
                <ComboBoxItem>растворимый порошок</ComboBoxItem>
                <ComboBoxItem>таблетки</ComboBoxItem>
                <ComboBoxItem>капсулы</ComboBoxItem>
                <ComboBoxItem>гель</ComboBoxItem>
                <ComboBoxItem>аэрозоль</ComboBoxItem>
                <ComboBoxItem>паста</ComboBoxItem>
                <ComboBoxItem>брикеты</ComboBoxItem>
                <ComboBoxItem>микрогранулы</ComboBoxItem>
                <ComboBoxItem>масляный раствор</ComboBoxItem>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="btnSave" Content="💾 Сохранить" Background="#27AE60" Foreground="White" 
                        Width="130" Height="40" FontSize="14" Margin="0,0,15,0" Cursor="Hand"/>
                <Button x:Name="btnCancel" Content="❌ Отмена" Background="#95A5A6" Foreground="White" 
                        Width="130" Height="40" FontSize="14" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>