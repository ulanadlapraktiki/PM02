<Window x:Class="TechnologistModule.Dialogs.AddTechMapDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание тех. карты" Height="410" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,-6">
        <StackPanel Margin="25,25,25,-36" RenderTransformOrigin="0.5,0.5">
            <StackPanel.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleX="0.105"/>
                    <RotateTransform/>
                    <TranslateTransform X="0.434"/>
                </TransformGroup>
            </StackPanel.RenderTransform>
            <TextBlock Text="Новая технологическая карта" FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Название" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtName" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="Версия" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtVersion" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5" Text="1"/>

            <TextBlock Text="ID продукта" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtProductId" Height="35" FontSize="14" Margin="0,0,0,20" Padding="8,5"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="btnSave" Content="Сохранить" Background="#27AE60" Foreground="White" 
                        Width="120" Height="38" FontSize="14" Margin="0,0,15,0"/>
                <Button x:Name="btnCancel" Content="Отмена" Background="#95A5A6" Foreground="White" 
                        Width="120" Height="38" FontSize="14"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>