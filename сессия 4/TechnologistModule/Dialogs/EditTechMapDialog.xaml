<Window x:Class="TechnologistModule.Dialogs.EditTechMapDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="✏️ Редактирование тех. карты" Height="380" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1">
        <StackPanel Margin="25,25,25,-1">
            <TextBlock Text="Редактирование тех. карты" FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Название" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtName" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="Версия" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtVersion" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="ID продукта" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtProductId" Height="35" FontSize="14" Margin="0,0,0,20" Padding="8,5"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnSave" Content="💾 Сохранить" Background="#27AE60" Foreground="White" 
                        Width="120" Height="38" FontSize="14" Margin="0,0,15,0"/>
                <Button x:Name="btnCancel" Content="❌ Отмена" Background="#95A5A6" Foreground="White" 
                        Width="120" Height="38" FontSize="14"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>