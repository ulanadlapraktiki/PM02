<Window x:Class="TechnologistModule.Dialogs.AddOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="➕ Создание заказа" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1">
        <StackPanel Margin="25,25,25,-24">
            <TextBlock Text="Новый производственный заказ" FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#2C3E50"/>

            <TextBlock Text="Номер заказа" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
            <TextBox x:Name="txtNumber" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="Количество (кг)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
            <TextBox x:Name="txtQuantity" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5" Text="1000"/>

            <TextBlock Text="Плановая дата запуска" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
            <DatePicker x:Name="dpDate" Height="35" FontSize="14" Margin="0,0,0,25"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="btnSave" Content="💾 Сохранить" Background="#27AE60" Foreground="White" 
                        Width="130" Height="40" FontSize="14" Margin="0,0,15,0" Cursor="Hand"/>
                <Button x:Name="btnCancel" Content="❌ Отмена" Background="#95A5A6" Foreground="White" 
                        Width="130" Height="40" FontSize="14" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>