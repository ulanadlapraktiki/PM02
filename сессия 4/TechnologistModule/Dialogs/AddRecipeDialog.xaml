<Window x:Class="TechnologistModule.Dialogs.AddRecipeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="➕ Создание рецептуры" Height="350" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1">
        <StackPanel Margin="25,25,25,9">
            <TextBlock Text="Новая рецептура" FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#2C3E50"/>

            <TextBlock Text="Название рецептуры" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
            <TextBox x:Name="txtName" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

            <TextBlock Text="Версия" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
            <TextBox x:Name="txtVersion" Height="35" FontSize="14" Margin="0,0,0,25" Padding="8,5" Text="1"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="btnSave" Content="💾 Сохранить" Background="#27AE60" Foreground="White" 
                        Width="130" Height="40" FontSize="14" Margin="0,0,15,0" Cursor="Hand"/>
                <Button x:Name="btnCancel" Content="❌ Отмена" Background="#95A5A6" Foreground="White" 
                        Width="130" Height="40" FontSize="14" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>