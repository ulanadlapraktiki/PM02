<Window x:Class="OperatorModule.Dialogs.EmergencyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🚨 АВАРИЙНАЯ ОСТАНОВКА" Height="450" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <Border Background="White" CornerRadius="10" BorderBrush="#E74C3C" BorderThickness="2">
        <StackPanel Margin="25">
            <TextBlock Text="⚠️ ПОДТВЕРЖДЕНИЕ АВАРИЙНОЙ ОСТАНОВКИ" 
                       FontSize="18" FontWeight="Bold" Foreground="#E74C3C" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Вы действительно хотите остановить партию?" 
                       FontSize="14" Foreground="Black" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Причина остановки:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbReason" Height="35" Margin="0,0,0,15" SelectedIndex="0">
                <ComboBoxItem>Отказ оборудования</ComboBoxItem>
                <ComboBoxItem>Отклонение параметров</ComboBoxItem>
                <ComboBoxItem>Безопасность</ComboBoxItem>
                <ComboBoxItem>Проблема с сырьем</ComboBoxItem>
                <ComboBoxItem>Другое</ComboBoxItem>
            </ComboBox>

            <TextBlock Text="Комментарий" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtComment" Height="80" TextWrapping="Wrap" 
                     AcceptsReturn="True" Margin="0,0,0,20" Padding="8,5"/>

            <TextBlock x:Name="lblError" Foreground="Red" FontSize="12" 
                       TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnConfirm" Content="✅ ПОДТВЕРДИТЬ" Background="#E74C3C" 
                        Foreground="White" Width="160" Height="40" FontSize="14" 
                        Margin="0,0,15,0" Cursor="Hand"/>
                <Button x:Name="btnCancel" Content="❌ ОТМЕНА" Background="#95A5A6" 
                        Foreground="White" Width="120" Height="40" FontSize="14" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>