<UserControl x:Class="LaboratoryModule.Views.RawMaterialBatchesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📦 Сырье - входной контроль" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Фильтры" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <WrapPanel>
                    <TextBox x:Name="txtSearch" Width="200" Height="32" Margin="0,0,10,10" 
                             Tag="Поиск по номеру или материалу" Foreground="Gray"/>
                    <ComboBox x:Name="cmbStatus" Width="150" Height="32" Margin="0,0,10,10" SelectedIndex="0">
                        <ComboBoxItem>Все статусы</ComboBoxItem>
                        <ComboBoxItem>Ожидает анализа</ComboBoxItem>
                        <ComboBoxItem>В работе</ComboBoxItem>
                        <ComboBoxItem>Разрешено</ComboBoxItem>
                        <ComboBoxItem>Заблокировано</ComboBoxItem>
                    </ComboBox>
                    <ComboBox x:Name="cmbSupplier" Width="150" Height="32" Margin="0,0,10,10"/>
                    <DatePicker x:Name="dpStart" Width="120" Height="32" Margin="0,0,10,10"/>
                    <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker x:Name="dpEnd" Width="120" Height="32" Margin="0,0,10,10"/>
                    <Button x:Name="btnSearch" Content="🔍 Поиск" Background="#3498DB" Foreground="White" 
                            Width="80" Height="32" Margin="0,0,10,10"/>
                    <Button x:Name="btnReset" Content="🔄 Сброс" Background="#7F8C8D" Foreground="White" 
                            Width="80" Height="32" Margin="0,0,10,10"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnRefresh" Content="🔄 Обновить" Background="#7F8C8D" Foreground="White" Padding="15,8"/>
            <ProgressBar x:Name="progress" Width="100" Height="4" Margin="10,0,0,0" IsIndeterminate="True" Visibility="Collapsed"/>
        </StackPanel>

        <DataGrid x:Name="grid" Grid.Row="3" AutoGenerateColumns="False" IsReadOnly="True" 
                  Margin="0,10,0,0" FontSize="13" AlternatingRowBackground="#F8F9FA"
                  SelectionChanged="Grid_SelectionChanged">
            <DataGrid.Resources>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding LabStatus}" Value="awaiting">
                            <Setter Property="Background" Value="#FFFDE8"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding LabStatus}" Value="in_progress">
                            <Setter Property="Background" Value="#E8F4FD"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding LabStatus}" Value="approved">
                            <Setter Property="Background" Value="#E8F8E8"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding LabStatus}" Value="blocked">
                            <Setter Property="Background" Value="#FDE8E8"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ партии" Binding="{Binding BatchNumber}" Width="100"/>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding SupplierName}" Width="150"/>
                <DataGridTextColumn Header="Дата поступления" Binding="{Binding ArrivalDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding LabStatus}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LabStatus}" Value="awaiting">
                                    <Setter Property="Foreground" Value="#F39C12"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LabStatus}" Value="in_progress">
                                    <Setter Property="Foreground" Value="#3498DB"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LabStatus}" Value="approved">
                                    <Setter Property="Foreground" Value="#27AE60"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LabStatus}" Value="blocked">
                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Действие" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🔬 Анализ" Background="#27AE60" Foreground="White" 
                                Width="70" Height="25" FontSize="11" Cursor="Hand"
                                Click="BtnAnalyze_Click" Tag="{Binding}"/>  
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>