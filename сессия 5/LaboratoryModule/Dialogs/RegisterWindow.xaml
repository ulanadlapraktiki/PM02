<Window x:Class="LaboratoryModule.Dialogs.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📝 Регистрация нового пользователя" Height="650" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Background="White" CornerRadius="10" BorderBrush="#BDC3C7" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25" Height="858">
                <TextBlock Text="Регистрация нового пользователя" FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#2C3E50"/>

                <TextBlock Text="Логин *" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
                <TextBox x:Name="txtUsername" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

                <TextBlock Text="Пароль *" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
                <PasswordBox x:Name="txtPassword" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

                <TextBlock Text="Подтверждение пароля *" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
                <PasswordBox x:Name="txtConfirmPassword" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

                <TextBlock Text="ФИО *" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
                <TextBox x:Name="txtFullName" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

                <TextBlock Text="Роль" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
                <ComboBox x:Name="cmbRole" Height="35" FontSize="14" Margin="0,0,0,15" Padding="5">
                    <ComboBoxItem>laboratory - Лаборант</ComboBoxItem>
                    <ComboBoxItem>technologist - Технолог</ComboBoxItem>
                    <ComboBoxItem>operator - Аппаратчик</ComboBoxItem>
                    <ComboBoxItem>manager - Руководитель</ComboBoxItem>
                    <ComboBoxItem>engineer - Инженер</ComboBoxItem>
                </ComboBox>

                <TextBlock Text="Email" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
                <TextBox x:Name="txtEmail" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

                <TextBlock Text="Телефон" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
                <TextBox x:Name="txtPhone" Height="35" FontSize="14" Margin="0,0,0,15" Padding="8,5"/>

                <TextBlock Text="Отдел" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
                <TextBox x:Name="txtDepartment" Height="35" FontSize="14" Margin="0,0,0,25" Padding="8,5"/>

                <TextBlock Text="Код с картинки *" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#34495E"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Image x:Name="imgCaptcha" Width="160" Height="50" Stretch="Fill"/>
                    <Button x:Name="btnRefreshCaptcha" Content="⟳" Width="40" Margin="5,0,0,0" Cursor="Hand"/>
                </StackPanel>
                <TextBox x:Name="txtCaptcha" Height="35" FontSize="14" Margin="0,0,0,10" Padding="8,5"/>

                <TextBlock x:Name="lblError" Foreground="Red" Margin="0,5,0,5" TextWrapping="Wrap" FontSize="12"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="btnRegister" Content="📝 Зарегистрироваться" Background="#27AE60" Foreground="White" 
                            Width="180" Height="40" FontSize="14" Margin="0,0,15,0" Cursor="Hand"/>
                    <Button x:Name="btnCancel" Content="❌ Отмена" Background="#95A5A6" Foreground="White" 
                            Width="120" Height="40" FontSize="14" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>