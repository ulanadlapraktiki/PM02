<Window x:Class="LaboratoryModule.Dialogs.TestSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лабораторное испытание" Height="744" Width="850"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="0,0,0,-6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto" MinHeight="70"/>
        </Grid.RowDefinitions>

        <!-- Информация о партии -->
        <Border Background="#F0F0F0" CornerRadius="8" Padding="15" Margin="10,10,10,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Партия:" FontWeight="Bold" Grid.Row="0" Grid.Column="0"/>
                <TextBlock x:Name="lblBatchNumber" Grid.Row="0" Grid.Column="1"/>
                <TextBlock Text="Материал/Продукт:" FontWeight="Bold" Grid.Row="0" Grid.Column="2"/>
                <TextBlock x:Name="lblMaterialName" Grid.Row="0" Grid.Column="3"/>

                <TextBlock Text="Тип контроля:" FontWeight="Bold" Grid.Row="1" Grid.Column="0"/>
                <TextBlock x:Name="lblControlType" Grid.Row="1" Grid.Column="1"/>
                <TextBlock Text="Статус:" FontWeight="Bold" Grid.Row="1" Grid.Column="2"/>
                <TextBlock x:Name="lblStatus" Grid.Row="1" Grid.Column="3" Foreground="#3498DB" FontWeight="Bold"/>

                <TextBlock Text="Приоритет:" FontWeight="Bold" Grid.Row="2" Grid.Column="0"/>
                <ComboBox x:Name="cmbPriority" Width="120" Grid.Row="2" Grid.Column="1" SelectedIndex="1">
                    <ComboBoxItem>Низкий</ComboBoxItem>
                    <ComboBoxItem>Обычный</ComboBoxItem>
                    <ComboBoxItem>Высокий</ComboBoxItem>
                    <ComboBoxItem>Срочный</ComboBoxItem>
                </ComboBox>
                <TextBlock Text="Дата создания:" FontWeight="Bold" Grid.Row="2" Grid.Column="2"/>
                <TextBlock x:Name="lblCreatedDate" Grid.Row="2" Grid.Column="3"/>
            </Grid>
        </Border>

        <!-- Параметры испытания -->
        <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="10,10,10,10">
            <StackPanel>
                <TextBlock Text="Параметры контроля" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                <DataGrid x:Name="gridParameters" AutoGenerateColumns="False" Height="280" 
                          Margin="0,0,0,10" FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Параметр" Binding="{Binding ParameterName}" Width="150" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Норма (мин)" Binding="{Binding MinValue}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Норма (макс)" Binding="{Binding MaxValue}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Ед.изм" Binding="{Binding Unit}" Width="80" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="Значение" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox x:Name="txtValue" 
                                         Text="{Binding MeasuredValue, UpdateSourceTrigger=LostFocus}" 
                                         Width="100" Height="25" TextAlignment="Center"
                                         LostFocus="TxtValue_LostFocus" 
                                         Tag="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Статус" Binding="{Binding IsValid}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding IsValid}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsValid}" Value="True">
                                            <Setter Property="Text" Value="✅ OK"/>
                                            <Setter Property="Foreground" Value="Green"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsValid}" Value="False">
                                            <Setter Property="Text" Value="❌ Отклонение"/>
                                            <Setter Property="Foreground" Value="Red"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Комментарий" Binding="{Binding AnalystComment}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button x:Name="btnAddParameter" Content="➕ Добавить параметр" Background="#27AE60" 
                        Foreground="White" Width="160" Height="32" FontSize="12" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Комментарий -->
        <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="10,10,10,10">
            <StackPanel>
                <TextBlock Text="Комментарий лаборанта" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtComment" Height="66" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,15" Width="782">
            <Button x:Name="btnSaveProgress" Content="💾 Сохранить промежуточные результаты" 
                    Background="#3498DB" Foreground="White" Width="259" Height="40" 
                    Margin="0,0,10,0" Cursor="Hand"/>
            <Button x:Name="btnComplete" Content="✅ Завершить испытание и принять решение" 
                    Background="#27AE60" Foreground="White" Width="284" Height="40" 
                    Cursor="Hand" Margin="0,0,10,0"/>
            <Button x:Name="btnProtocol" Content="📄 Протокол" Background="#9B59B6" 
                    Foreground="White" Width="100" Height="40" Margin="0,0,10,0" Cursor="Hand"/>
            <Button x:Name="btnCancel" Content="❌ Отмена" Background="#95A5A6" 
                    Foreground="White" Width="100" Height="40" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>